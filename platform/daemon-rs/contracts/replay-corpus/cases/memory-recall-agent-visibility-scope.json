      }
    ],
    "ignoreJsonPaths": ["$.meta.timings", "$.results[*].score", "$.results[*].createdAt", "$.results[*].updatedAt"]
  },
  "expectedInternalState": {
    "db": [
      {
        "table": "memories",
        "where": "id LIKE 'mem-recall-%'",
        "count": 4
      },
      {
        "table": "memories",
        "where": "id LIKE 'mem-recall-%'",
        "orderBy": ["id"],
        "columns": ["id", "agent_id", "visibility", "is_deleted"],
        "rows": [
