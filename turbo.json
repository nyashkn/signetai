{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", "build/**", "dashboard/**", "target/**", "!.svelte-kit/**"]
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"lint": {
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"@signetai/connector-opencode#build": {
			"dependsOn": ["@signet/opencode-plugin#build", "^build"],
			"outputs": ["dist/**", "build/**", "dashboard/**", "target/**", "!.svelte-kit/**"]
		},
		"@signetai/connector-oh-my-pi#build": {
			"dependsOn": ["@signet/oh-my-pi-extension#build", "^build"],
			"outputs": ["dist/**", "build/**", "dashboard/**", "target/**", "!.svelte-kit/**"]
		},
		"@signetai/connector-pi#build": {
			"dependsOn": ["@signet/pi-extension#build", "^build"],
			"outputs": ["dist/**", "build/**", "dashboard/**", "target/**", "!.svelte-kit/**"]
		},
		"signetai#build": {
			"dependsOn": [
				"@signetai/core#build",
				"@signetai/connector-base#build",
				"@signetai/connector-claude-code#build",
				"@signetai/connector-codex#build",
				"@signetai/connector-hermes-agent#build",
				"@signetai/connector-oh-my-pi#build",
				"@signetai/connector-openclaw#build",
				"@signetai/connector-opencode#build",
				"@signetai/connector-pi#build",
				"@signet/daemon#build"
			],
			"outputs": ["dist/**", "build/**", "dashboard/**", "target/**", "!.svelte-kit/**"]
		}
	}
}
