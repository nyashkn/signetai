---
const harnesses = [
	{
		name: "Claude Code",
		href: "https://docs.anthropic.com/en/docs/claude-code",
		note: "Hooks + CLAUDE.md sync",
		key: "claudecode",
		status: "Supported",
	},
	{
		name: "OpenCode",
		href: "https://github.com/sst/opencode",
		note: "Plugin + AGENTS.md sync",
		key: "opencode",
		status: "Supported",
	},
	{
		name: "OpenClaw",
		href: "https://github.com/openclaw/openclaw",
		note: "Runtime plugin + NemoClaw compatible",
		key: "openclaw",
		status: "Supported",
	},
	{
		name: "Codex",
		href: "https://github.com/openai/codex",
		note: "Hooks + MCP server",
		key: "codex",
		status: "Supported",
	},
	{
		name: "Oh My Pi",
		href: "https://github.com/Signet-AI/signetai/tree/main/integrations/oh-my-pi/connector",
		note: "Managed runtime extension",
		key: "ohmypi",
		status: "Supported",
	},
	{
		name: "Hermes Agent",
		href: "https://github.com/NousResearch/hermes-agent",
		note: "Memory provider plugin",
		key: "hermesagent",
		status: "Supported",
	},
	{
		name: "Gemini CLI",
		href: "https://github.com/google-gemini/gemini-cli",
		note: "MCP server + GEMINI.md sync",
		key: "gemini",
		status: "Supported",
	},
];
---

<section id="harnesses" class="container" style="border-top: 1px solid var(--color-border)">
  <div class="section-header reveal">
    <div class="crosshair"></div>
    <span class="section-label">Harnesses</span>
    <span class="section-index">03 / 08</span>
  </div>

  <p class="lp-label reveal" style="margin-bottom: var(--space-md);">
    Signet installs under your existing harness, not instead of it. Same memory, same identity, same secrets — across every tool.
  </p>

  <div class="harness-grid reveal">
    {harnesses.map((harness) => (
      <a href={harness.href} class="harness-card" target="_blank" rel="noopener noreferrer">
        <div class="harness-card-logo" aria-hidden="true">
          {harness.key === 'claudecode' && (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor">
              <path d="m3.127 10.604 3.135-1.76.053-.153-.053-.085H6.11l-.525-.032-1.791-.048-1.554-.065-1.505-.08-.38-.081L0 7.832l.036-.234.32-.214.455.04 1.009.069 1.513.105 1.097.064 1.626.17h.259l.036-.105-.089-.065-.068-.064-1.566-1.062-1.695-1.121-.887-.646-.48-.327-.243-.306-.104-.67.435-.48.585.04.15.04.593.456 1.267.981 1.654 1.218.242.202.097-.068.012-.049-.109-.181-.9-1.626-.96-1.655-.428-.686-.113-.411a2 2 0 0 1-.068-.484l.496-.674L4.446 0l.662.089.279.242.411.94.666 1.48 1.033 2.014.302.597.162.553.06.17h.105v-.097l.085-1.134.157-1.392.154-1.792.052-.504.25-.605.497-.327.387.186.319.456-.045.294-.19 1.23-.37 1.93-.243 1.29h.142l.161-.16.654-.868 1.097-1.372.484-.545.565-.601.363-.287h.686l.505.751-.226.775-.707.895-.585.759-.839 1.13-.524.904.048.072.125-.012 1.897-.403 1.024-.186 1.223-.21.553.258.06.263-.218.536-1.307.323-1.533.307-2.284.54-.028.02.032.04 1.029.098.44.024h1.077l2.005.15.525.346.315.424-.053.323-.807.411-3.631-.863-.872-.218h-.12v.073l.726.71 1.331 1.202 1.667 1.55.084.383-.214.302-.226-.032-1.464-1.101-.565-.497-1.28-1.077h-.084v.113l.295.432 1.557 2.34.08.718-.112.234-.404.141-.444-.08-.911-1.28-.94-1.44-.759-1.291-.093.053-.448 4.821-.21.246-.484.186-.403-.307-.214-.496.214-.98.258-1.28.21-1.016.19-1.263.112-.42-.008-.028-.092.012-.953 1.307-1.448 1.957-1.146 1.227-.274.109-.477-.247.045-.44.266-.39 1.586-2.018.956-1.25.617-.723-.004-.105h-.036l-4.212 2.736-.75.096-.324-.302.04-.496.154-.162 1.267-.871z"/>
            </svg>
          )}
          {harness.key === 'opencode' && (
            <svg viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M320 224V352H192V224H320Z" fill="currentColor" opacity="0.4"/>
              <path fill-rule="evenodd" clip-rule="evenodd" d="M384 416H128V96H384V416ZM320 160H192V352H320V160Z" fill="currentColor"/>
            </svg>
          )}
          {harness.key === 'openclaw' && (
            <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M60 10 C30 10 15 35 15 55 C15 75 30 95 45 100 L45 110 L55 110 L55 100 C55 100 60 102 65 100 L65 110 L75 110 L75 100 C90 95 105 75 105 55 C105 35 90 10 60 10Z" fill="currentColor" opacity="0.8"/>
              <path d="M20 45 C5 40 0 50 5 60 C10 70 20 65 25 55 C28 48 25 45 20 45Z" fill="currentColor" opacity="0.6"/>
              <path d="M100 45 C115 40 120 50 115 60 C110 70 100 65 95 55 C92 48 95 45 100 45Z" fill="currentColor" opacity="0.6"/>
              <circle cx="45" cy="35" r="6" fill="var(--color-bg)"/>
              <circle cx="75" cy="35" r="6" fill="var(--color-bg)"/>
              <circle cx="46" cy="34" r="2.5" fill="currentColor"/>
              <circle cx="76" cy="34" r="2.5" fill="currentColor"/>
            </svg>
          )}
          {harness.key === 'codex' && (
            <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/>
            </svg>
          )}
          {harness.key === 'ohmypi' && (
            <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm3.5 5.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3zm-7 0a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3zM12 19c-3.314 0-6-2.015-6-4.5h1.5c0 1.657 2.015 3 4.5 3s4.5-1.343 4.5-3H18c0 2.485-2.686 4.5-6 4.5z"/>
            </svg>
          )}
          {harness.key === 'hermesagent' && (
            <svg viewBox="0 0 64 64" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <rect x="30" y="10" width="4" height="46" rx="2" fill="currentColor"/>
              <path d="M30 18 C24 14, 14 14, 10 18 C14 16, 22 16, 28 20" fill="currentColor" opacity="0.9"/>
              <path d="M30 22 C26 19, 18 19, 14 22 C18 20, 24 20, 28 24" fill="currentColor" opacity="0.7"/>
              <path d="M34 18 C40 14, 50 14, 54 18 C50 16, 42 16, 36 20" fill="currentColor" opacity="0.9"/>
              <path d="M34 22 C38 19, 46 19, 50 22 C46 20, 40 20, 36 24" fill="currentColor" opacity="0.7"/>
              <path d="M32 48 C22 44, 20 38, 26 34 C20 36, 18 42, 24 46 C18 40, 22 30, 30 28 C24 32, 22 38, 28 42" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M32 48 C42 44, 44 38, 38 34 C44 36, 46 42, 40 46 C46 40, 42 30, 34 28 C40 32, 42 38, 36 42" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="32" cy="10" r="4" fill="currentColor"/>
              <circle cx="32" cy="10" r="2" fill="currentColor" opacity="0.4"/>
            </svg>
          )}
          {harness.key === 'gemini' && (
            <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm0 2.4a9.6 9.6 0 0 1 6.6 2.634A9.552 9.552 0 0 1 12 7.2a9.552 9.552 0 0 1-6.6-2.166A9.6 9.6 0 0 1 12 2.4zM2.4 12a9.56 9.56 0 0 1 2.634-6.6A9.552 9.552 0 0 1 7.2 12a9.552 9.552 0 0 1-2.166 6.6A9.56 9.56 0 0 1 2.4 12zm9.6 9.6a9.6 9.6 0 0 1-6.6-2.634A9.552 9.552 0 0 1 12 16.8a9.552 9.552 0 0 1 6.6 2.166A9.6 9.6 0 0 1 12 21.6zm9.6-9.6a9.56 9.56 0 0 1-2.634 6.6A9.552 9.552 0 0 1 16.8 12a9.552 9.552 0 0 1 2.166-6.6A9.56 9.56 0 0 1 21.6 12z"/>
            </svg>
          )}
        </div>
        <h3 class="harness-card-name">{harness.name}</h3>
        <p class="harness-card-note">{harness.note}</p>
        {harness.status === 'First-party' ? (
          <span class="lp-badge-highlight">{harness.status}</span>
        ) : harness.status === 'Planned' ? (
          <span class="harness-card-status harness-card-status--planned">{harness.status}</span>
        ) : (
          <span class="harness-card-status">{harness.status}</span>
        )}
      </a>
    ))}
  </div>
</section>
