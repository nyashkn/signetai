---
---

<section id="capabilities" class="container" style="border-top: 1px solid var(--color-border)">
  <div class="section-header reveal">
    <div class="crosshair"></div>
    <span class="section-label">CAPABILITIES</span>
    <span class="section-index">02 / 04</span>
  </div>

  <div class="cap-grid reveal">
    <!-- Row 1: Ambient Memory (2 cols) -->
    <div class="cap-cell cap-ambient">
      <div class="cap-header">
        <span class="cap-fig">FIG_01 // AMBIENT_FLOW</span>
        <div class="cap-status">
          <span class="cap-dot"></span>
          ACTIVE_STREAM
        </div>
      </div>
      <div class="cap-illustration">
        <svg viewBox="0 0 400 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- Flowing data points -->
          <g class="data-flow">
            {[0, 1, 2].map((i) => (
              <circle cx={20 + i * 40} cy="60" r="1.5" fill="var(--color-accent)" opacity="0.4">
                <animate attributeName="cx" from={20 + i * 40} to={380 + i * 40} dur="3s" repeatCount="indefinite" begin={`${i}s`} />
                <animate attributeName="opacity" values="0;0.4;0" dur="3s" repeatCount="indefinite" begin={`${i}s`} />
              </circle>
            ))}
          </g>
          
          <line x1="20" y1="60" x2="380" y2="60" stroke="currentColor" stroke-opacity="0.08" stroke-dasharray="4 4"/>
          
          <!-- Memory Blocks -->
          <rect x="140" y="30" width="40" height="60" rx="4" stroke="var(--color-accent)" stroke-opacity="0.3" fill="var(--color-accent)" fill-opacity="0.05" class="block-pulse" style="animation-delay: 0s" />
          <rect x="190" y="20" width="40" height="80" rx="4" stroke="var(--color-accent)" stroke-opacity="0.5" fill="var(--color-accent)" fill-opacity="0.08" class="block-pulse" style="animation-delay: 0.5s" />
          <rect x="240" y="40" width="40" height="40" rx="4" stroke="var(--color-accent)" stroke-opacity="0.2" fill="var(--color-accent)" fill-opacity="0.03" class="block-pulse" style="animation-delay: 1s" />
          
          <!-- Connection lines to blocks -->
          <path d="M160 90 L160 105 L180 105" stroke="var(--color-accent)" stroke-opacity="0.2" fill="none" stroke-width="1"/>
          <circle cx="185" cy="105" r="2" fill="var(--color-accent)" fill-opacity="0.3"/>
        </svg>
      </div>
      <div class="cap-body">
        <h3 class="cap-title">Ambient Memory</h3>
        <p class="cap-desc">Every session is automatically distilled into structured memory. No tool calls, no manual saves — your agent wakes up knowing what happened yesterday.</p>
      </div>
    </div>

    <!-- Row 1/2: Knowledge Graph (1 col, spans 2 rows) -->
    <div class="cap-cell cap-graph">
      <div class="cap-header">
        <span class="cap-fig">FIG_02 // KNOWLEDGE_GRAPH</span>
      </div>
      <div class="cap-illustration">
        <svg viewBox="0 0 200 240" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- Complex Graph -->
          <g class="graph-lines">
            <line x1="100" y1="40" x2="40" y2="100" stroke="var(--color-accent)" stroke-opacity="0.2" stroke-width="1"/>
            <line x1="100" y1="40" x2="160" y2="90" stroke="var(--color-accent)" stroke-opacity="0.2" stroke-width="1"/>
            <line x1="40" y1="100" x2="70" y2="180" stroke="var(--color-accent)" stroke-opacity="0.15" stroke-width="1"/>
            <line x1="160" y1="90" x2="130" y2="170" stroke="var(--color-accent)" stroke-opacity="0.15" stroke-width="1"/>
            <line x1="70" y1="180" x2="130" y2="170" stroke="var(--color-electric)" stroke-opacity="0.1" stroke-width="1" stroke-dasharray="2 2"/>
            <line x1="40" y1="100" x2="160" y2="90" stroke="var(--color-accent)" stroke-opacity="0.1" stroke-width="1"/>
            <line x1="100" y1="40" x2="100" y2="120" stroke="var(--color-accent)" stroke-opacity="0.1" stroke-width="1"/>
          </g>
          
          <circle cx="100" cy="40" r="6" fill="var(--color-accent)" fill-opacity="0.3" stroke="var(--color-accent)" stroke-opacity="0.5" class="node-pulse"/>
          <circle cx="40" cy="100" r="4" fill="var(--color-accent)" fill-opacity="0.2" stroke="var(--color-accent)" stroke-opacity="0.4" class="node-pulse" style="animation-delay: 0.3s"/>
          <circle cx="160" cy="90" r="4" fill="var(--color-accent)" fill-opacity="0.2" stroke="var(--color-accent)" stroke-opacity="0.4" class="node-pulse" style="animation-delay: 0.6s"/>
          <circle cx="70" cy="180" r="3" fill="var(--color-electric)" fill-opacity="0.15" stroke="var(--color-electric)" stroke-opacity="0.3" class="node-pulse" style="animation-delay: 0.9s"/>
          <circle cx="130" cy="170" r="3" fill="var(--color-electric)" fill-opacity="0.15" stroke="var(--color-electric)" stroke-opacity="0.3" class="node-pulse" style="animation-delay: 1.2s"/>
          <circle cx="100" cy="120" r="2.5" fill="var(--color-text-muted)" fill-opacity="0.2" stroke="var(--color-text-muted)" stroke-opacity="0.3"/>
        </svg>
      </div>
      <div class="cap-body">
        <h3 class="cap-title">Knowledge Graph</h3>
        <p class="cap-desc">Entities and relationships extracted with high precision. Graph traversal allows for deep context retrieval.</p>
      </div>
    </div>

    <!-- Row 2: Inspect (1 col) -->
    <div class="cap-cell cap-inspect">
      <div class="cap-header">
        <span class="cap-fig">FIG_03 // INSPECTION_UI</span>
      </div>
      <div class="cap-illustration">
        <svg viewBox="0 0 240 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="10" y="10" width="220" height="100" rx="6" stroke="currentColor" stroke-opacity="0.1" fill="var(--color-surface)" fill-opacity="0.5"/>
          <line x1="10" y1="30" x2="230" y2="30" stroke="currentColor" stroke-opacity="0.08"/>
          
          <!-- Window controls -->
          <circle cx="22" cy="20" r="2" fill="currentColor" opacity="0.2"/>
          <circle cx="30" cy="20" r="2" fill="currentColor" opacity="0.2"/>
          <circle cx="38" cy="20" r="2" fill="currentColor" opacity="0.2"/>
          
          <!-- UI Content -->
          <rect x="20" y="40" width="60" height="6" rx="2" fill="var(--color-accent)" fill-opacity="0.2"/>
          <rect x="20" y="52" width="40" height="4" rx="2" fill="currentColor" opacity="0.05"/>
          
          <rect x="90" y="40" width="130" height="20" rx="3" stroke="var(--color-accent)" stroke-opacity="0.15" fill="var(--color-accent)" fill-opacity="0.03"/>
          <rect x="98" y="48" width="80" height="4" rx="2" fill="var(--color-accent)" fill-opacity="0.2"/>
          
          <rect x="90" y="66" width="130" height="20" rx="3" stroke="currentColor" stroke-opacity="0.08" fill="none"/>
          <rect x="98" y="74" width="60" height="4" rx="2" fill="currentColor" opacity="0.05"/>
        </svg>
      </div>
      <div class="cap-body">
        <h3 class="cap-title">Inspect Everything</h3>
        <p class="cap-desc">Memory is not a black box. Browse, search, and edit through a refined dashboard with full provenance.</p>
      </div>
    </div>

    <!-- Row 2: Cross-platform (1 col) -->
    <div class="cap-cell cap-cross">
      <div class="cap-header">
        <span class="cap-fig">FIG_04 // CROSS_HARNESS</span>
      </div>
      <div class="cap-body">
        <h3 class="cap-title">Cross-Platform</h3>
        <p class="cap-desc">A unified agent state layer that keeps identity and memory coherent across every major AI agent harness.</p>
        <div class="cap-platforms">
          <span>Claude Code</span>
          <span>OpenCode</span>
          <span>OpenClaw</span>
          <span>Codex</span>
        </div>
      </div>
    </div>

    <!-- Row 3: Secrets -->
    <div class="cap-cell cap-secrets">
      <div class="cap-header">
        <span class="cap-fig">FIG_05 // CRYPTO_LAYER</span>
      </div>
      <div class="cap-icon-wrap">
        <svg class="cap-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="5" y="10" width="14" height="11" rx="2" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.8"/>
          <path d="M8 10V7C8 4.79086 9.79086 3 12 3C14.2091 3 16 4.79086 16 7V10" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.6"/>
          <circle cx="12" cy="15.5" r="1.5" fill="var(--color-accent)" fill-opacity="0.4"/>
        </svg>
      </div>
      <div class="cap-body">
        <h3 class="cap-title">Encrypted Secrets</h3>
        <p class="cap-desc">Industry-standard encryption at rest. Agents utilize credentials without ever exposing plaintext.</p>
      </div>
    </div>

    <!-- Row 3: Multi-Agent -->
    <div class="cap-cell cap-multi">
      <div class="cap-header">
        <span class="cap-fig">FIG_06 // MULTI_TENANT</span>
      </div>
      <div class="cap-icon-wrap">
        <svg class="cap-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.7"/>
          <path d="M5 20C5 17.2386 8.13401 15 12 15C15.866 15 19 17.2386 19 20" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.5"/>
          <circle cx="18" cy="14" r="3" stroke="var(--color-electric)" stroke-width="1.2" stroke-opacity="0.4"/>
        </svg>
      </div>
      <div class="cap-body">
        <h3 class="cap-title">Multi-Agent</h3>
        <p class="cap-desc">Granular visibility controls. Define isolated, shared, or group memory scopes for swarms.</p>
      </div>
    </div>

    <!-- Row 3: Scorer -->
    <div class="cap-cell cap-scorer">
      <div class="cap-header">
        <span class="cap-fig">FIG_07 // CONTEXT_RANKING</span>
      </div>
      <div class="cap-icon-wrap">
        <svg class="cap-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M3 18L9 12L13 16L21 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" stroke-opacity="0.8"/>
          <circle cx="21" cy="6" r="2.5" fill="var(--color-accent)" fill-opacity="0.5" class="node-pulse"/>
        </svg>
      </div>
      <div class="cap-body">
        <h3 class="cap-title">Context Ranking</h3>
        <p class="cap-desc">Inspectable ranking, provenance, and dampening keep useful context visible without flooding the model window.</p>
      </div>
    </div>

    <!-- Row 4: And more — single spanning row -->
    <div class="cap-cell cap-more">
      <div class="cap-more-label">
        <span class="cap-fig">FIG_08 // EXTENSIONS</span>
        <h3 class="cap-title">Core Ecosystem</h3>
      </div>
      <div class="cap-more-list">
        <span>SDK & React Hooks</span>
        <span>CLI Interface</span>
        <span>Git Provider Sync</span>
        <span>Skills Marketplace</span>
        <span>Docker / Self-Host</span>
        <span>MCP Support</span>
      </div>
    </div>
  </div>
</section>

<style>
  .cap-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 40px;
  }

  .cap-cell {
    background: color-mix(in srgb, var(--color-surface) 40%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    overflow: hidden;
    transition: all 0.4s var(--ease);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .cap-cell::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent, rgba(200, 255, 0, 0.02));
    opacity: 0;
    transition: opacity 0.4s var(--ease);
  }

  .cap-cell:hover {
    border-color: var(--color-border-strong);
    background: color-mix(in srgb, var(--color-surface) 60%, transparent);
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
  }

  .cap-cell:hover::before {
    opacity: 1;
  }

  .cap-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
  }

  .cap-fig {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    opacity: 0.5;
  }

  .cap-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .cap-dot {
    width: 4px;
    height: 4px;
    background: var(--color-accent);
    border-radius: 50%;
    box-shadow: 0 0 4px var(--color-accent);
  }

  .cap-ambient {
    grid-column: span 2;
  }

  .cap-graph {
    grid-row: span 2;
  }

  .cap-title {
    font-family: var(--font-display);
    font-size: 16px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-bright);
    margin-bottom: 6px;
  }

  .cap-desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .cap-illustration {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
    transition: opacity 0.4s var(--ease);
  }

  .cap-cell:hover .cap-illustration {
    opacity: 1;
  }

  .cap-platforms {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 12px;
  }

  .cap-platforms span {
    font-family: var(--font-mono);
    font-size: 9px;
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.02);
  }

  .cap-more {
    grid-column: span 3;
    flex-direction: row;
    align-items: center;
    gap: 40px;
    padding: 32px 40px;
  }

  .cap-more-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    flex: 1;
    justify-content: flex-end;
  }

  .cap-more-list span {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 6px 14px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.02);
    transition: all 0.3s var(--ease);
  }

  .cap-cell:hover .cap-more-list span {
    border-color: var(--color-accent);
    color: var(--color-text-bright);
    background: var(--color-highlight-dim);
  }

  .block-pulse {
    animation: blockPulse 4s ease-in-out infinite;
  }
  
  @keyframes blockPulse {
    0%, 100% { opacity: 0.3; stroke-opacity: 0.3; transform: scale(0.98); }
    50% { opacity: 0.6; stroke-opacity: 0.6; transform: scale(1); }
  }
  
  .node-pulse {
    animation: nodePulse 3s ease-in-out infinite;
    transform-origin: center;
  }
  
  @keyframes nodePulse {
    0%, 100% { transform: scale(1); opacity: 0.4; filter: blur(0px); }
    50% { transform: scale(1.3); opacity: 0.8; filter: blur(1px); }
  }

  .data-flow circle {
    filter: drop-shadow(0 0 2px var(--color-accent));
  }

  .cap-icon-wrap {
    height: 32px;
    display: flex;
    align-items: center;
    color: var(--color-accent);
  }

  .cap-icon {
    width: 24px;
    height: 24px;
    opacity: 0.7;
    transition: all 0.4s var(--ease);
  }

  .cap-cell:hover .cap-icon {
    opacity: 1;
    transform: scale(1.1);
    filter: drop-shadow(0 0 8px var(--color-highlight-muted));
  }

  .graph-lines line {
    transition: all 0.6s var(--ease);
  }

  .cap-cell:hover .graph-lines line {
    stroke-opacity: 0.5;
    stroke-width: 1.5;
  }

  @media (max-width: 960px) {
    .cap-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .cap-ambient, .cap-more {
      grid-column: span 2;
    }
  }

  @media (max-width: 640px) {
    .cap-grid {
      grid-template-columns: 1fr;
    }
    .cap-ambient, .cap-graph, .cap-more {
      grid-column: span 1;
      grid-row: span 1;
    }
    .cap-more {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .cap-more-list {
      justify-content: flex-start;
    }
  }
</style>
