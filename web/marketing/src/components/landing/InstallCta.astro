---
---

<section id="install" class="container" style="border-top: 1px solid var(--color-border)">
  <div class="section-header reveal">
    <div class="crosshair"></div>
    <span class="section-label">GET STARTED</span>
    <span class="section-index">04 / 04</span>
  </div>

  <div class="install-final reveal">
    <h2 class="install-final-title">Your agent has memory in five minutes.</h2>

    <div class="install-final-grid">
      <div class="install-final-step">
        <span class="install-final-num">01</span>
        <div class="install-final-content">
          <h3 class="install-final-label">Install</h3>
          <div class="install-box">
            <span class="install-prompt">$</span>
            <span class="install-cmd">curl -fsSL https://signetai.sh/install.sh | bash</span>
            <button class="copy-btn push-right" data-copy="curl -fsSL https://signetai.sh/install.sh | bash" aria-label="Copy command">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
            </button>
          </div>
          <span class="install-final-alt">package managers: <code>npm i -g signetai</code> or <code>bun add -g signetai</code></span>
        </div>
      </div>

      <div class="install-final-step">
        <span class="install-final-num">02</span>
        <div class="install-final-content">
          <h3 class="install-final-label">Setup</h3>
          <p class="install-final-desc">Run <code>signet setup</code>, pick your harness, and the daemon starts automatically. Hooks are installed. Identity files are created.</p>
        </div>
      </div>

      <div class="install-final-step">
        <span class="install-final-num">03</span>
        <div class="install-final-content">
          <h3 class="install-final-label">Work</h3>
          <p class="install-final-desc">Open your coding agent and start a session. Memory extraction happens automatically. Next session, context is already there.</p>
        </div>
      </div>
    </div>

    <div class="install-final-footer">
      <div class="install-final-meta">
        <span>Apache 2.0</span>
        <span class="install-final-sep">&middot;</span>
        <span>Open Source</span>
        <span class="install-final-sep">&middot;</span>
        <span>Local-first</span>
      </div>
      <div class="install-final-links">
        <a href="/join" class="btn btn-primary">Join Community</a>
        <a href="/docs/quickstart" class="btn btn-ghost">Quickstart docs</a>
        <a href="https://github.com/Signet-AI/signetai" class="btn btn-ghost">GitHub</a>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy');
      if (text) {
        await navigator.clipboard.writeText(text);
        btn.classList.add('is-copied');
        setTimeout(() => btn.classList.remove('is-copied'), 1500);
      }
    });
  });
</script>
