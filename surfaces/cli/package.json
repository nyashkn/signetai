{
  "name": "@signet/cli",
  "version": "0.109.6",
  "description": "CLI for Signet - portable AI agent identity",
  "type": "module",
  "bin": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js",
    "./browse": "./src/browse.ts"
  },
  "files": [
    "dist",
    "templates",
    "skills"
  ],
  "scripts": {
    "build": "bun run build:cli",
    "build:cli": "bun build ./src/cli.ts --outfile ./dist/cli.js --target node --external better-sqlite3",
    "build:dashboard": "cd ../dashboard && bun install && bun run build",
    "dev": "bun --watch src/cli.ts",
    "dev:dashboard": "cd ../dashboard && bun run dev",
    "copy:skills": "rm -rf skills && cp -r ../../skills skills",
    "prebuild": "bun run copy:skills",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "keywords": [
    "signet",
    "ai",
    "agent",
    "identity",
    "memory",
    "cli",
    "portable"
  ],
  "author": "Nicholai",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signetai/signetai.git"
  },
  "homepage": "https://signetai.sh",
  "dependencies": {
    "@signet/core": "workspace:*",
    "@signet/connector-claude-code": "workspace:*",
    "@signet/connector-codex": "workspace:*",
    "@signet/connector-forge": "workspace:*",
    "@signet/connector-gemini": "workspace:*",
    "@signet/connector-hermes-agent": "workspace:*",
    "@signet/connector-opencode": "workspace:*",
    "@signet/connector-openclaw": "workspace:*",
    "@signet/connector-oh-my-pi": "workspace:*",
    "@signet/connector-pi": "workspace:*",
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "open": "^10.0.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
